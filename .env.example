# PostgreSQL
POSTGRES_USER=dockguard
POSTGRES_PASSWORD=dockguard
POSTGRES_DB=dockguard

# Backend
DATABASE_URL=postgresql+asyncpg://dockguard:dockguard@postgres:5432/dockguard
CORS_ORIGINS=["http://localhost:3000"]
TRIVY_TIMEOUT=600
BUILD_TIMEOUT=600
MAX_CONCURRENT_SCANS=3
MAX_PENDING_SCANS=25
STATS_RECENT_SCAN_LIMIT=100
DOCKER_GID=1001

# Redis (optional — cache disabled when absent)
REDIS_URL=redis://redis:6379/0

# Frontend (server-side proxy to backend — not exposed to browser)
API_URL=http://backend:8000
