aws_region    = "eu-west-3"
project       = "dockguard"
environment   = "prod"
instance_type = "t3.small"

db_instance_class = "db.t3.micro"
db_password       = "change_me_in_production"

# Paste the output of: cat ~/.ssh/id_ed25519.pub
ssh_public_key = "ssh-ed25519 AAAA... user@host"

# Restrict SSH access to your IP (e.g. "203.0.113.42/32")
ssh_allowed_cidr = "0.0.0.0/0"

ghcr_image_backend  = "ghcr.io/<your-github-username>/dockguard-backend:latest"
ghcr_image_frontend = "ghcr.io/<your-github-username>/dockguard-frontend:latest"
